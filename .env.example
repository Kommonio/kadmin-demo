# Kadmin Demo — Environment Variables
# Copy this file to .env and fill in the values

# Firebase (client)
REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=kadmin-demo.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=kadmin-demo
REACT_APP_FIREBASE_STORAGE_BUCKET=kadmin-demo.firebasestorage.app
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=
REACT_APP_FIREBASE_APP_ID=

# Firebase Admin (server)
FIREBASE_PROJECT_ID=kadmin-demo
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# API
REACT_APP_API_URL=/api
