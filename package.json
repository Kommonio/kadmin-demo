{
  "name": "kadmin-demo",
  "version": "1.0.0",
  "private": true,
  "description": "Kadmin Demo — Example project using the Kadmin framework",
  "scripts": {
    "install:client": "cd client && npm install",
    "install:server": "cd server && npm install",
    "install:all": "npm run install:client && npm run install:server",
    "build": "cd client && npm run build",
    "dev:client": "cd client && npm start",
    "dev:server": "cd server && npm run dev",
    "seed:roles": "node scripts/pushCollection.js Roles scripts/data/roles/",
    "seed:samples": "node scripts/pushCollection.js Samples scripts/data/samples/",
    "seed:all": "npm run seed:roles && npm run seed:samples",
    "fetch": "node scripts/fetchDocument.js"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "firebase-admin": "^13.0.2"
  }
}
